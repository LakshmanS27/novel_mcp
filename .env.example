# Required
DLP_MCP_APP_HOST=127.0.0.1
DLP_MCP_APP_PORT=8081


DLP_MCP_SERVER_URL=http://localhost:8081/mcp

# LLM Provider Configuration (Multi-Provider Support)
# The system auto-detects providers based on available API keys in this priority:
# 1. CommandCode (if COMMANDCODE_API_KEY is set)
# 2. OpenAI (if OPENAI_API_KEY is set)
# 3. OpenRouter (if OPENROUTER_API_KEY is set)
#
# Only ONE provider needs to be configured - the system will use the first one
# with a valid API key.

# --- OpenRouter Provider (Default) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# --- OpenAI Provider ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- CommandCode Provider ---
COMMANDCODE_API_KEY=your-commandcode-api-key
COMMANDCODE_BASE_URL=https://api.commandcode.ai/provider/v1
COMMANDCODE_MODEL=commandcode-v1

# Optional
DLP_MCP_APP_NAME=Risk-Aware MCP DLP
DLP_MCP_LOG_LEVEL=INFO

DLP_MCP_DEFAULT_TREE_DEPTH=3
DLP_MCP_MAX_TREE_DEPTH=8
DLP_MCP_STAT_CONCURRENCY=64
DLP_MCP_SIMILARITY_BUCKET_LIMIT=64
DLP_MCP_SCAN_PERCENT=0.05
DLP_MCP_MAX_SCAN_PERCENT=0.05
DLP_MCP_MIN_SCAN_PERCENT=0.01

DLP_MCP_DB_PATH=/home/youruser/novel-mcp/mcp_server/data/state.db
DLP_MCP_PROMPTS_DIR=/home/youruser/novel-mcp/mcp_server/prompts

# Server-side LLM Override (Optional)
# By default, the server auto-detects providers as above.
# Only set DLP_MCP_LLM_* if you want to override the auto-detected provider.
DLP_MCP_LLM_BASE_URL=
DLP_MCP_LLM_API_KEY=
DLP_MCP_LLM_MODEL=
DLP_MCP_LLM_TIMEOUT_SECONDS=30.0
DLP_MCP_LLM_ENABLED=true

DLP_MCP_MAX_FILE_READ_BYTES=2000000
DLP_MCP_SCAN_CHUNK_SIZE=8192
